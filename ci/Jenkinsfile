pipeline {
    agent any

    environment {
        NODEJS_VERSION = '20'
        BASE_URL = "${env.BASE_URL ?: 'https://the-internet.herokuapp.com'}"
    }

    tools {
        nodejs "${NODEJS_VERSION}"
    }

    stages {
        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Install') {
            steps {
                sh 'npm ci'
                sh 'npx playwright install --with-deps chromium'
            }
        }

        stage('Lint & Typecheck') {
            steps {
                sh 'npm run lint'
                sh 'npm run typecheck'
            }
        }

        stage('Test: Smoke') {
            steps {
                sh 'npm run test:smoke'
            }
            post {
                always {
                    publishHTML([
                        allowMissing: true,
                        alwaysLinkToLastBuild: true,
                        keepAll: true,
                        reportDir: 'playwright-report',
                        reportFiles: 'index.html',
                        reportName: 'Playwright Smoke Report'
                    ])
                }
            }
        }

        stage('Test: Full Regression') {
            when { branch 'main' }
            steps {
                sh 'npm run test:regression'
            }
        }
    }

    post {
        always {
            archiveArtifacts artifacts: 'playwright-report/**', allowEmptyArchive: true
            archiveArtifacts artifacts: 'test-results/**', allowEmptyArchive: true
            junit allowEmptyResults: true, testResults: 'test-results/junit.xml'
        }
        failure {
            echo 'Tests failed! Check the Playwright report for details.'
        }
        success {
            echo 'All tests passed! Report by QA Pulse by SK - www.skakarh.com'
        }
    }
}
