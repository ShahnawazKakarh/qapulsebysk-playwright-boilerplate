{
  "name": "qapulsebysk-playwright-boilerplate",
  "version": "1.0.0",
  "description": "Production-grade Playwright test automation boilerplate by QA Pulse by SK",
  "main": "index.js",
  "scripts": {
    "test": "playwright test",
    "test:e2e": "playwright test tests/e2e --project=chromium",
    "test:api": "playwright test tests/api",
    "test:visual": "playwright test tests/visual",
    "test:a11y": "playwright test tests/accessibility",
    "test:component": "playwright test tests/component",
    "test:smoke": "playwright test --grep @smoke",
    "test:regression": "playwright test --grep @regression",
    "test:sanity": "playwright test --grep @sanity",
    "test:critical": "playwright test --grep @critical",
    "test:chromium": "playwright test --project=chromium",
    "test:firefox": "playwright test --project=firefox",
    "test:webkit": "playwright test --project=webkit",
    "test:ci": "CI=true playwright test",
    "test:debug": "playwright test --debug --project=chromium",
    "test:headed": "playwright test --headed --project=chromium",
    "test:update-snapshots": "playwright test --update-snapshots",
    "report:html": "playwright show-report playwright-report",
    "report:allure:generate": "allure generate allure-results --clean -o allure-report",
    "report:allure:open": "allure open allure-report",
    "report:allure": "npm run report:allure:generate && npm run report:allure:open",
    "report:json": "node reporters/jsonSummary.js",
    "format": "prettier --write .",
    "lint": "eslint . --ext .js"
  },
  "keywords": [
    "playwright",
    "javascript",
    "automation",
    "testing",
    "boilerplate",
    "qa",
    "qapulse",
    "page-object-model",
    "accessibility",
    "visual-regression",
    "allure"
  ],
  "author": "QA Pulse by SK - www.skakarh.com",
  "license": "MIT",
  "devDependencies": {
    "@axe-core/playwright": "^4.9.1",
    "@faker-js/faker": "^10.4.0",
    "@playwright/test": "^1.46.0",
    "allure-commandline": "^2.29.0",
    "allure-playwright": "^3.0.0",
    "dotenv": "^16.4.5",
    "eslint": "^8.57.0",
    "eslint-plugin-playwright": "^1.6.2",
    "prettier": "^3.3.0"
  }
}
